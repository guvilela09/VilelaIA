{
  "name": "@vilelaia/db",
  "version": "1.0.0",
  "description": "VilelaIA - Database",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "node --env-file=../../.env node_modules/.bin/drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "node --env-file=../../.env node_modules/.bin/drizzle-kit push --force --config ./drizzle.config.ts",
    "init": "node ./init-db.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
